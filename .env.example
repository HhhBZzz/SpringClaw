# ============================================================
# SpringClaw Docker Environment Variables
# ============================================================
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env && docker compose up -d
# ============================================================

# --- Infrastructure Credentials (CHANGE IN PRODUCTION!) ------
MYSQL_ROOT_PASSWORD=change-me-in-production
MYSQL_USER=root
MYSQL_DB=springclaw
RABBITMQ_USERNAME=springclaw
RABBITMQ_PASSWORD=change-me-in-production

# --- Memory Core Shadow Flags (Phase 3A1: disabled by default) ---
SPRINGCLAW_MEMORY_CORE_ENABLED=false
SPRINGCLAW_MEMORY_SHORT_TERM_SHADOW_ENABLED=false
SPRINGCLAW_MEMORY_INDEX_WORKER_ENABLED=false
SPRINGCLAW_MEMORY_SCHEMA_AUTO_INIT=true
SPRINGCLAW_MEMORY_SHORT_TERM_MAX_MESSAGES=40
SPRINGCLAW_MEMORY_SHORT_TERM_TTL_DAYS=7
SPRINGCLAW_MEMORY_FRAME_ENABLED=false
SPRINGCLAW_MEMORY_FRAME_SHADOW_COMPARE_ENABLED=false
SPRINGCLAW_MEMORY_FRAME_MAX_CHARS=6000
SPRINGCLAW_MEMORY_FRAME_TRACE_MAX_WARNINGS=20
SPRINGCLAW_CONTEXT_SNAPSHOT_FACTORY_ENABLED=false

# --- AI Provider API Keys ------------------------------------
SPRINGCLAW_AI_ACTIVE_PROVIDER=primary

SPRINGCLAW_PRIMARY_ENABLED=true
SPRINGCLAW_PRIMARY_API_KEY=
SPRINGCLAW_PRIMARY_BASE_URL=https://api.zhongzhuan.win
SPRINGCLAW_PRIMARY_MODEL=claude-opus-4-6

SPRINGCLAW_QWEN_ENABLED=true
SPRINGCLAW_QWEN_API_KEY=
SPRINGCLAW_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SPRINGCLAW_QWEN_MODEL=qwen3.5-plus

SPRINGCLAW_CODING_PLAN_ENABLED=true
SPRINGCLAW_CODING_PLAN_API_KEY=
SPRINGCLAW_CODING_PLAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
SPRINGCLAW_CODING_PLAN_MODEL=qwen3.5-plus
