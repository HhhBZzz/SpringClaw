# Copy to .env and replace every placeholder before a real deployment.
# The values in this template are deliberately non-production defaults.

# Public frontend binding. Keep loopback for a local deployment.
SPRINGCLAW_HTTP_BIND_ADDRESS=127.0.0.1
SPRINGCLAW_HTTP_PORT=8080

# Infrastructure credentials
MYSQL_ROOT_PASSWORD=replace-with-a-unique-root-password
MYSQL_DB=springclaw
MYSQL_USER=springclaw
MYSQL_PASSWORD=replace-with-a-unique-database-password
REDIS_PASSWORD=replace-with-a-unique-redis-password
RABBITMQ_USERNAME=springclaw
RABBITMQ_PASSWORD=replace-with-a-unique-rabbitmq-password

# Bootstrap and privileged behavior
SPRINGCLAW_ADMIN_USERNAMES=admin
SPRINGCLAW_PASSWORD_PEPPER=
SPRINGCLAW_AUTH_BOOTSTRAP_FIRST_USER_ADMIN=false
SPRINGCLAW_AUTH_COOKIE_SECURE=false
SPRINGCLAW_SYSTEM_COMMAND_ENABLED=false

# Webhook signature security. Set enabled=true and the applicable secret(s) for public ingress.
SPRINGCLAW_WEBHOOK_SECURITY_ENABLED=false
SPRINGCLAW_WEBHOOK_SECRET=
SPRINGCLAW_WEBHOOK_SECRET_TELEGRAM=
SPRINGCLAW_WEBHOOK_SECRET_WECHAT=
SPRINGCLAW_WEBHOOK_SECRET_FEISHU=

# Feishu delivery is disabled by default. Opt in with the relevant true flag and every required credential.
SPRINGCLAW_FEISHU_OUTBOUND_ENABLED=false
SPRINGCLAW_FEISHU_LONG_CONNECTION_ENABLED=false
SPRINGCLAW_FEISHU_APP_ID=
SPRINGCLAW_FEISHU_APP_SECRET=
SPRINGCLAW_FEISHU_VERIFICATION_TOKEN=
SPRINGCLAW_FEISHU_ENCRYPT_KEY=
SPRINGCLAW_FEISHU_DOMAIN=

# AI providers are disabled unless the corresponding credentials and endpoint are supplied.
SPRINGCLAW_AI_ACTIVE_PROVIDER=primary
SPRINGCLAW_PRIMARY_ENABLED=false
SPRINGCLAW_PRIMARY_API_KEY=
SPRINGCLAW_PRIMARY_BASE_URL=
SPRINGCLAW_PRIMARY_MODEL=
SPRINGCLAW_QWEN_ENABLED=false
SPRINGCLAW_QWEN_API_KEY=
SPRINGCLAW_QWEN_BASE_URL=
SPRINGCLAW_QWEN_MODEL=
SPRINGCLAW_CODING_PLAN_ENABLED=false
SPRINGCLAW_CODING_PLAN_API_KEY=
SPRINGCLAW_CODING_PLAN_BASE_URL=
SPRINGCLAW_CODING_PLAN_MODEL=
SPRINGCLAW_DEEPSEEK_ENABLED=false
SPRINGCLAW_DEEPSEEK_API_KEY=
SPRINGCLAW_DEEPSEEK_BASE_URL=
SPRINGCLAW_DEEPSEEK_MODEL=
SPRINGCLAW_VOLCENGINE_CODING_PLAN_ENABLED=false
SPRINGCLAW_VOLCENGINE_CODING_PLAN_API_KEY=
SPRINGCLAW_VOLCENGINE_CODING_PLAN_BASE_URL=
SPRINGCLAW_VOLCENGINE_CODING_PLAN_MODEL=
